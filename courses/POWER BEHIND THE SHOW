<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Power Behind the Show — AV Electrical Power Course by Akhil Sekhar</title>
<meta name="description" content="The only course built specifically for AV professionals who need to understand electrical power. 16 modules. Online. Self-paced.">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   DESIGN SYSTEM
══════════════════════════════════════ */
:root {
  --bg:      #040604;
  --bg2:     #060a06;
  --panel:   #090d09;
  --panel2:  #0c100c;
  --green:   #00FF41;
  --green-d: #00aa2b;
  --green-f: rgba(0,255,65,0.06);
  --green-f2:rgba(0,255,65,0.1);
  --amber:   #FFB300;
  --red:     #FF3333;
  --white:   #e8f0e8;
  --dim:     #1a3a1a;
  --label:   #3a6a3a;
  --text-d:  #5a7a5a;
  --border:  rgba(0,255,65,0.15);
  --border2: rgba(0,255,65,0.25);
  --gold:    #C9A84C;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  color: var(--white);
  font-family: 'Barlow', sans-serif;
  overflow-x: hidden;
  line-height: 1.6;
}

/* Scanlines */
body::before {
  content: '';
  position: fixed; inset: 0;
  background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.06) 2px, rgba(0,0,0,0.06) 4px);
  pointer-events: none; z-index: 9999;
}

/* ── UTILITY ── */
.mono { font-family: 'Share Tech Mono', monospace; }
.green { color: var(--green); }
.amber { color: var(--amber); }
.label-tag {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 4px; text-transform: uppercase;
  color: var(--label);
}
.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(36px, 5vw, 60px);
  letter-spacing: 0.05em;
  line-height: 1;
  color: var(--white);
}
.section-title .accent { color: var(--green); }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  background: rgba(4,6,4,0.92);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(12px);
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 40px; height: 56px;
  transition: all 0.3s;
}

.nav-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px; letter-spacing: 4px;
  color: var(--green);
  text-decoration: none;
  text-shadow: 0 0 20px rgba(0,255,65,0.3);
}

.nav-links {
  display: flex; gap: 28px; list-style: none;
}

.nav-links a {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
  color: var(--label); text-decoration: none; transition: color 0.15s;
}
.nav-links a:hover { color: var(--green); }

.nav-cta {
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px; letter-spacing: 3px;
  background: var(--green); color: #000;
  padding: 8px 20px; text-decoration: none;
  clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
  transition: all 0.15s;
}
.nav-cta:hover { background: #33ff6e; }

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
#hero {
  min-height: 100vh;
  display: flex; flex-direction: column; justify-content: center;
  padding: 120px 80px 80px;
  position: relative; overflow: hidden;
}

/* Background grid */
#hero::before {
  content: '';
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,255,65,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,65,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
}

/* Hero glow */
#hero::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(0,40,10,0.5) 0%, transparent 70%);
}

.hero-content { position: relative; z-index: 1; max-width: 900px; }

.hero-eyebrow {
  display: flex; align-items: center; gap: 16px;
  margin-bottom: 24px;
}

.hero-eyebrow::before {
  content: ''; display: block;
  width: 40px; height: 1px; background: var(--green-d);
}

.hero-badge {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 4px;
  color: var(--label); text-transform: uppercase;
}

.live-dot {
  display: inline-block; width: 6px; height: 6px;
  border-radius: 50%; background: var(--amber);
  box-shadow: 0 0 8px var(--amber);
  animation: pulse 2s infinite; margin-right: 6px;
}
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }

.hero-course-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(64px, 10vw, 130px);
  line-height: 0.88;
  letter-spacing: 0.04em;
  margin-bottom: 8px;
}

.hero-course-title .line1 { color: var(--white); display: block; }
.hero-course-title .line2 { color: var(--white); display: block; }
.hero-course-title .line3 { color: var(--green); display: block; text-shadow: 0 0 40px rgba(0,255,65,0.3); }

.hero-subtitle {
  font-size: clamp(16px, 2vw, 22px);
  font-weight: 300;
  color: rgba(232,240,232,0.55);
  max-width: 620px;
  line-height: 1.7;
  margin: 24px 0 40px;
}

.hero-subtitle strong { color: rgba(232,240,232,0.9); font-weight: 600; }

/* Stat row */
.hero-stats {
  display: flex; gap: 0; margin-bottom: 44px;
}

.hstat {
  padding: 16px 32px;
  border: 1px solid var(--border);
  border-right: none;
  background: var(--green-f);
  text-align: center;
}
.hstat:first-child { border-left: 1px solid var(--border); }
.hstat:last-child { border-right: 1px solid var(--border); }

.hstat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 40px; line-height: 1;
  color: var(--green); text-shadow: 0 0 20px rgba(0,255,65,0.3);
}
.hstat-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px; letter-spacing: 3px; color: var(--label);
  margin-top: 4px;
}

/* CTA group */
.hero-cta {
  display: flex; gap: 14px; align-items: center; flex-wrap: wrap;
}

.btn-primary {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px; letter-spacing: 4px; text-transform: uppercase;
  background: var(--green); color: #000;
  padding: 16px 40px; text-decoration: none;
  clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  transition: all 0.2s; border: none; cursor: pointer; display: inline-block;
}
.btn-primary:hover { background: #33ff6e; transform: translateY(-1px); }

.btn-secondary {
  font-family: 'Share Tech Mono', monospace;
  font-size: 12px; letter-spacing: 4px; text-transform: uppercase;
  background: transparent; color: var(--green);
  padding: 15px 40px; text-decoration: none;
  border: 1px solid var(--border2); transition: all 0.2s; display: inline-block;
}
.btn-secondary:hover { background: var(--green-f2); border-color: var(--green); }

.hero-note {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 2px; color: var(--label);
  margin-top: 16px;
}

/* Hero right — power diagram preview */
.hero-visual {
  position: absolute; right: 80px; top: 50%; transform: translateY(-50%);
  width: 340px; opacity: 0.6; z-index: 1;
}

.hv-label {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px; letter-spacing: 3px; color: var(--label);
  margin-bottom: 8px;
}

canvas#hero-canvas { display: block; width: 100%; }

/* ══════════════════════════════════════
   PROBLEM STATEMENT
══════════════════════════════════════ */
#problem {
  padding: 100px 80px;
  background: var(--bg2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  position: relative; overflow: hidden;
}

#problem::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 50% at 0% 50%, rgba(0,255,65,0.03) 0%, transparent 60%);
}

.problem-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  position: relative; z-index: 1;
  max-width: 1100px; margin: 0 auto;
}

.problem-left .label-tag { margin-bottom: 20px; }

.problem-statement {
  font-size: clamp(22px, 3vw, 34px);
  font-weight: 300;
  line-height: 1.5;
  color: var(--white);
  margin-bottom: 28px;
}

.problem-statement em {
  font-style: normal;
  color: var(--green);
  font-weight: 600;
}

.problem-body {
  font-size: 16px;
  color: rgba(232,240,232,0.5);
  line-height: 1.8;
}

/* Pain points */
.pain-list { display: flex; flex-direction: column; gap: 14px; }

.pain-item {
  display: flex; align-items: flex-start; gap: 14px;
  padding: 16px 20px;
  border: 1px solid rgba(255,51,51,0.12);
  background: rgba(255,51,51,0.04);
  transition: all 0.2s;
}
.pain-item:hover { border-color: rgba(255,51,51,0.25); background: rgba(255,51,51,0.07); }

.pain-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
.pain-text { font-size: 14px; color: rgba(232,240,232,0.65); line-height: 1.5; }
.pain-text strong { color: var(--white); font-weight: 600; }

/* ══════════════════════════════════════
   WHAT YOU'LL LEARN
══════════════════════════════════════ */
#learn {
  padding: 100px 80px;
  position: relative; overflow: hidden;
}

#learn::before {
  content: '';
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,255,65,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,65,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
}

.learn-header {
  text-align: center;
  max-width: 700px; margin: 0 auto 60px;
  position: relative; z-index: 1;
}

.learn-header .label-tag { margin-bottom: 16px; }

.outcomes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  position: relative; z-index: 1;
  max-width: 1100px; margin: 0 auto;
}

.outcome-card {
  background: var(--panel);
  border: 1px solid var(--border);
  padding: 28px 24px;
  transition: all 0.2s;
  position: relative; overflow: hidden;
}

.outcome-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--green-d), transparent);
  opacity: 0; transition: opacity 0.2s;
}

.outcome-card:hover { background: var(--panel2); border-color: var(--border2); }
.outcome-card:hover::before { opacity: 1; }

.oc-icon { font-size: 28px; margin-bottom: 14px; }
.oc-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 20px; letter-spacing: 2px;
  color: var(--green); margin-bottom: 8px;
}
.oc-body { font-size: 13px; color: rgba(232,240,232,0.5); line-height: 1.6; }

/* ══════════════════════════════════════
   CURRICULUM
══════════════════════════════════════ */
#curriculum {
  padding: 100px 80px;
  background: var(--bg2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.curriculum-layout {
  display: grid;
  grid-template-columns: 360px 1fr;
  gap: 80px;
  align-items: start;
  max-width: 1100px; margin: 0 auto;
}

.curriculum-intro .label-tag { margin-bottom: 20px; }
.curriculum-intro .section-title { margin-bottom: 20px; }
.curriculum-intro p {
  font-size: 15px; color: rgba(232,240,232,0.5); line-height: 1.8;
  margin-bottom: 32px;
}

.curriculum-meta {
  display: flex; flex-direction: column; gap: 10px;
}

.cm-item {
  display: flex; align-items: center; gap: 12px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px; letter-spacing: 1px; color: var(--label);
}
.cm-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); flex-shrink: 0; }

/* Module list */
.module-list { display: flex; flex-direction: column; gap: 2px; }

.module-item {
  display: flex; align-items: stretch; gap: 0;
  border: 1px solid var(--border);
  background: var(--panel);
  cursor: pointer; transition: all 0.2s;
  position: relative; overflow: hidden;
}

.module-item:hover { background: var(--panel2); border-color: var(--border2); }

.module-num {
  width: 56px; flex-shrink: 0;
  background: var(--green-f);
  border-right: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 22px; color: var(--green-d);
  letter-spacing: 1px;
}

.module-content { flex: 1; padding: 14px 18px; }

.module-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 17px; letter-spacing: 2px;
  color: var(--white); margin-bottom: 3px;
  transition: color 0.15s;
}
.module-item:hover .module-title { color: var(--green); }

.module-desc {
  font-size: 12px; color: var(--text-d); line-height: 1.4;
}

.module-tag {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px; letter-spacing: 2px;
  padding: 3px 8px; border: 1px solid;
  align-self: center; margin-right: 14px; flex-shrink: 0;
  white-space: nowrap;
}

.tag-core { border-color: rgba(0,255,65,0.2); color: var(--green-d); }
.tag-safety { border-color: rgba(255,51,51,0.2); color: var(--red); }
.tag-practical { border-color: rgba(255,179,0,0.2); color: var(--amber); }

/* ══════════════════════════════════════
   WHO IT'S FOR
══════════════════════════════════════ */
#for-who {
  padding: 100px 80px;
  position: relative; overflow: hidden;
}

#for-who::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 60% at 100% 50%, rgba(0,255,65,0.03) 0%, transparent 60%);
}

.for-who-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  max-width: 1100px; margin: 0 auto;
  position: relative; z-index: 1;
}

.for-who-cards {
  display: flex; flex-direction: column; gap: 14px;
}

.who-card {
  display: flex; align-items: flex-start; gap: 16px;
  padding: 18px 22px;
  border: 1px solid var(--border);
  background: var(--panel);
  transition: all 0.2s;
}
.who-card:hover { background: var(--panel2); border-color: var(--border2); }

.who-icon { font-size: 24px; flex-shrink: 0; }
.who-role {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px; letter-spacing: 2px;
  color: var(--green); margin-bottom: 4px;
}
.who-desc { font-size: 13px; color: rgba(232,240,232,0.5); line-height: 1.5; }

/* NOT for section */
.not-for-list {
  margin-top: 28px;
  border: 1px solid rgba(255,51,51,0.1);
  padding: 18px 22px;
  background: rgba(255,51,51,0.03);
}
.nf-title {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 3px; color: rgba(255,51,51,0.5);
  margin-bottom: 10px;
}
.nf-item {
  font-size: 13px; color: rgba(232,240,232,0.35);
  padding: 4px 0; border-bottom: 1px solid rgba(255,51,51,0.06);
  display: flex; align-items: center; gap: 8px;
}
.nf-item:last-child { border-bottom: none; }
.nf-item::before { content: '✕'; color: rgba(255,51,51,0.4); font-size: 10px; }

/* ══════════════════════════════════════
   INSTRUCTOR
══════════════════════════════════════ */
#instructor {
  padding: 100px 80px;
  background: var(--bg2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.instructor-layout {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 64px;
  align-items: start;
  max-width: 1100px; margin: 0 auto;
}

/* Avatar — signal monitor style */
.instructor-avatar {
  width: 200px; flex-shrink: 0;
}

.avatar-frame {
  border: 2px solid var(--border);
  background: var(--panel);
  padding: 16px;
  position: relative;
}

.avatar-frame::before {
  content: 'INSTRUCTOR';
  position: absolute; top: -8px; left: 14px;
  background: var(--bg2); padding: 0 6px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 7px; letter-spacing: 3px; color: var(--label);
}

.avatar-placeholder {
  width: 100%;
  aspect-ratio: 1;
  background: var(--green-f);
  border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 60px; color: var(--green-d);
  letter-spacing: 4px;
  margin-bottom: 10px;
}

.avatar-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 18px; letter-spacing: 3px;
  color: var(--green); text-align: center;
}

.avatar-title {
  font-family: 'Share Tech Mono', monospace;
  font-size: 8px; letter-spacing: 2px;
  color: var(--label); text-align: center; margin-top: 3px;
}

/* Credentials */
.instructor-bio .label-tag { margin-bottom: 16px; }
.instructor-bio h3 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 36px; letter-spacing: 3px;
  color: var(--white); margin-bottom: 20px;
}

.bio-text {
  font-size: 15px; color: rgba(232,240,232,0.6);
  line-height: 1.8; margin-bottom: 28px;
}
.bio-text strong { color: var(--white); }

.cred-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.cred-item {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 13px; color: rgba(232,240,232,0.6); line-height: 1.4;
}
.cred-item::before { content: '▸'; color: var(--green); flex-shrink: 0; margin-top: 2px; }

/* ══════════════════════════════════════
   PRICING
══════════════════════════════════════ */
#pricing {
  padding: 100px 80px;
  position: relative; overflow: hidden;
}

#pricing::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,255,65,0.04) 0%, transparent 60%);
}

.pricing-header {
  text-align: center; max-width: 600px;
  margin: 0 auto 60px;
  position: relative; z-index: 1;
}
.pricing-header .label-tag { margin-bottom: 16px; }

.pricing-cards {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 2px;
  max-width: 900px; margin: 0 auto;
  position: relative; z-index: 1;
}

.price-card {
  background: var(--panel);
  border: 1px solid var(--border);
  padding: 36px 28px;
  display: flex; flex-direction: column;
  transition: all 0.2s;
  position: relative; overflow: hidden;
}

.price-card.featured {
  background: var(--panel2);
  border-color: var(--border2);
  box-shadow: 0 0 40px rgba(0,255,65,0.06);
}

.price-card.featured::before {
  content: 'BEST VALUE';
  position: absolute; top: 0; left: 0; right: 0;
  background: var(--green); color: #000;
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 4px;
  text-align: center; padding: 5px;
}

.price-card.featured { padding-top: 48px; }

.pc-tier {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 4px;
  color: var(--label); margin-bottom: 12px;
}

.pc-price {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 56px; line-height: 1;
  color: var(--green); text-shadow: 0 0 20px rgba(0,255,65,0.2);
  margin-bottom: 4px;
}

.pc-price .currency {
  font-size: 24px; vertical-align: top;
  margin-top: 10px; display: inline-block;
}

.pc-price-note {
  font-family: 'Share Tech Mono', monospace;
  font-size: 9px; letter-spacing: 2px;
  color: var(--label); margin-bottom: 24px;
  text-decoration: line-through;
}

.pc-divider {
  height: 1px; background: var(--border);
  margin-bottom: 20px;
}

.pc-features {
  flex: 1; display: flex; flex-direction: column; gap: 10px;
  margin-bottom: 28px;
}

.pc-feat {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 13px; color: rgba(232,240,232,0.6); line-height: 1.4;
}
.pc-feat::before { content: '✓'; color: var(--green); flex-shrink: 0; font-family: 'Share Tech Mono',monospace; }
.pc-feat.no { color: rgba(232,240,232,0.25); }
.pc-feat.no::before { content: '–'; color: var(--dim); }

.btn-card {
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
  padding: 13px; text-align: center; text-decoration: none;
  transition: all 0.2s; border: none; cursor: pointer; display: block;
}
.btn-card-primary { background: var(--green); color: #000; }
