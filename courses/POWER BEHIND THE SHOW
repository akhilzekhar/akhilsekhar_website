<script>
// Scroll animations
const fadeEls = document.querySelectorAll('.fade-up');
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } });
}, { threshold: 0.1 });
fadeEls.forEach(el => obs.observe(el));

// FAQ toggle
function toggleFaq(el) {
  const ans = el.nextElementSibling;
  const tog = el.querySelector('.faq-toggle');
  const isOpen = ans.classList.contains('open');
  document.querySelectorAll('.faq-a').forEach(a => a.classList.remove('open'));
  document.querySelectorAll('.faq-toggle').forEach(t => t.style.transform = '');
  if(!isOpen) { ans.classList.add('open'); tog.style.transform = 'rotate(45deg)'; }
}

// Form submit
function handleSubmit(e) {
  e.preventDefault();
  const email = document.getElementById('email-input').value;
  const msg = document.getElementById('form-message');
  msg.textContent = '✓ You\'re on the list. We\'ll be in touch.';
  document.getElementById('email-input').value = '';
  // TODO: Replace with actual Apps Script endpoint
  // fetch('YOUR_APPS_SCRIPT_URL', { method:'POST', body: JSON.stringify({email}) })
}

// Hero canvas — animated power chain
(function() {
  const cv = document.getElementById('hero-canvas');
  if(!cv) return;
  const ctx = cv.getContext('2d');
  let t = 0;

  const nodes = [
    {label:'MAINS',x:.05,col:'#FFB300'},
    {label:'GEN',x:.2,col:'#FFB300'},
    {label:'DISTRO',x:.38,col:'#00EEFF'},
    {label:'STAGE',x:.56,col:'#00FF41'},
    {label:'SERVERS',x:.74,col:'#00FF41'},
    {label:'OUT',x:.92,col:'#00FF9E'},
  ];

  function draw() {
    cv.width = cv.offsetWidth;
    cv.height = 280;
    const W = cv.width, H = cv.height;
    ctx.clearRect(0,0,W,H);

    // Grid
    ctx.strokeStyle = 'rgba(0,255,65,0.06)';
    ctx.lineWidth = 1;
    for(let x=0;x<W;x+=30){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke();}
    for(let y=0;y<H;y+=30){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke();}

    // Connections
    for(let i=0;i<nodes.length-1;i++){
      const a = nodes[i], b = nodes[i+1];
      const x1=a.x*W, x2=b.x*W, y=H*.5;
      // Animated energy pulse
      const progress = ((t * 0.02 + i * 0.2) % 1);
      const px = x1 + (x2-x1)*progress;

      ctx.beginPath();
      ctx.strokeStyle = 'rgba(0,255,65,0.2)';
      ctx.lineWidth = 2;
      ctx.moveTo(x1, y);
      ctx.lineTo(x2, y);
      ctx.stroke();

      // Pulse dot
      ctx.beginPath();
      ctx.arc(px, y, 3, 0, Math.PI*2);
      ctx.fillStyle = '#00FF41';
      ctx.shadowColor = '#00FF41';
      ctx.shadowBlur = 8;
      ctx.fill();
      ctx.shadowBlur = 0;
    }

    // Nodes
    nodes.forEach(n => {
      const x = n.x*W, y = H*.5;
      ctx.beginPath();
      ctx.arc(x, y, 8, 0, Math.PI*2);
      ctx.fillStyle = '#040604';
      ctx.fill();
      ctx.strokeStyle = n.col;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      ctx.fillStyle = n.col;
      ctx.font = `${Math.max(8,W/50)}px 'Share Tech Mono', monospace`;
      ctx.textAlign = 'center';
      ctx.fillText(n.label, x, y + 22);
    });

    // Waveform below
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(0,255,65,0.25)';
    ctx.lineWidth = 1;
    for(let x=0;x<W;x++){
      const y2 = H*.78 + Math.sin(x*.05+t*.04)*12 + Math.sin(x*.09+t*.06)*6;
      x===0 ? ctx.moveTo(x,y2) : ctx.lineTo(x,y2);
    }
    ctx.stroke();

    t++;
    requestAnimationFrame(draw);
  }
  draw();
  window.addEventListener('resize', draw);
})();
</script>
